{
  "name": "workflow-wrapper",
  "version": "1.2.0",
  "description": "Hackathon CLI orchestration layer for treehouse, lavish, gnhf, and no-mistakes",
  "bin": {
    "wfw": "./bin/hack-wrap.sh",
    "wfw-mcp": "./mcp/dist/index.js"
  },
  "scripts": {
    "build:mcp": "npm --prefix mcp install && npm --prefix mcp run build",
    "prepublishOnly": "npm run build:mcp",
    "setup": "bash bin/postinstall.sh",
    "install-mcp": "bash bin/install-mcp.sh",
    "install-skill": "bash bin/install-skill.sh",
    "test:integration": "bash tests/integration/test-shared-lavish-plan.sh"
  },
  "files": [
    "bin",
    "skills",
    "mcp/dist",
    "mcp/prompts",
    "mcp/package.json"
  ],
  "keywords": [
    "cli",
    "workflow",
    "hackathon",
    "treehouse",
    "lavish",
    "gnhf",
    "no-mistakes"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sea1vester/workflow-Wrapper.git"
  },
  "bugs": {
    "url": "https://github.com/Sea1vester/workflow-Wrapper/issues"
  },
  "homepage": "https://github.com/Sea1vester/workflow-Wrapper#readme"
}
